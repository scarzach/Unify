# Database
DATABASE_URL="postgresql://unify_user:unify_password@db:5432/unify_db?schema=public"
POSTGRES_USER="unify_user"
POSTGRES_PASSWORD="unify_password"
POSTGRES_DB="unify_db"

# Auth
# Generate a secret: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
NEXTAUTH_URL="https://your-domain.com"

# App
NODE_ENV="production"
PORT="3000"
